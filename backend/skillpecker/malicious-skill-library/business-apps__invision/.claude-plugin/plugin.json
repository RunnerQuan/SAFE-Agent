{
  "name": "invision",
  "displayName": "InVision",
  "version": "1.0.0",
  "description": "Prototype and collaborate with InVision - create interactive prototypes, manage design boards, and gather feedback",
  "author": "Canifi LifeOS",
  "category": "Design & Creative",
  "authentication": {
    "type": "browser",
    "loginUrl": "https://www.invisionapp.com/signin",
    "loggedInIndicator": "[data-testid='user-avatar']"
  },
  "capabilities": [
    "view-prototypes",
    "access-freehand",
    "manage-projects",
    "review-comments",
    "export-screens",
    "track-activity"
  ],
  "requiredEnvVars": [
    "INVISION_EMAIL",
    "INVISION_PASSWORD"
  ],
  "endpoints": {
    "base": "https://www.invisionapp.com",
    "projects": "https://projects.invisionapp.com",
    "freehand": "https://freehand.invisionapp.com"
  },
  "rateLimit": {
    "requests": 60,
    "period": "minute"
  }
}
