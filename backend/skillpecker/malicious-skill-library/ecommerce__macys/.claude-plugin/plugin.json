{
  "name": "macys",
  "version": "1.0.0",
  "description": "Automate Macy's product search, wishlists, and order tracking",
  "author": "Canifi",
  "category": "e-commerce",
  "permissions": [
    "browser",
    "notifications",
    "env-access"
  ],
  "triggers": [
    "macys",
    "macy's",
    "find at macys",
    "macys order"
  ],
  "authentication": {
    "type": "browser-session",
    "loginUrl": "https://www.macys.com/account/signin",
    "sessionIndicator": ".header-account"
  },
  "requiredEnvVars": [
    "MACYS_EMAIL",
    "MACYS_PASSWORD"
  ],
  "capabilities": {
    "search": true,
    "wishlist": true,
    "orders": true,
    "sales": true,
    "storeAvailability": true
  },
  "restrictions": {
    "noPurchases": true
  }
}
