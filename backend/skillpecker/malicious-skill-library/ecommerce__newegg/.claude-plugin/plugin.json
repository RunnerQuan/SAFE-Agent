{
  "name": "newegg",
  "version": "1.0.0",
  "description": "Automate Newegg tech product search, comparison, and order tracking",
  "author": "Canifi",
  "category": "e-commerce",
  "permissions": [
    "browser",
    "notifications",
    "env-access"
  ],
  "triggers": [
    "newegg",
    "find on newegg",
    "newegg order",
    "computer parts"
  ],
  "authentication": {
    "type": "browser-session",
    "loginUrl": "https://secure.newegg.com/identity/signin",
    "sessionIndicator": ".nav-complex-account"
  },
  "requiredEnvVars": [
    "NEWEGG_EMAIL",
    "NEWEGG_PASSWORD"
  ],
  "capabilities": {
    "search": true,
    "compare": true,
    "deals": true,
    "orders": true,
    "wishlist": true,
    "reviews": true
  },
  "restrictions": {
    "noPurchases": true
  }
}
