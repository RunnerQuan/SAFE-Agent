# Azure AI Speech Fast Transcription Configuration

# Required: Azure Speech Service endpoint
# Format: https://{region}.api.cognitive.microsoft.com/
AZURE_AI_SPEECH_ENDPOINT=https://swedencentral.api.cognitive.microsoft.com/

# Required: Azure Speech Service API key
AZURE_AI_SPEECH_KEY=your-speech-api-key

# Optional: Azure OpenAI for post-processing (summarization, sentiment)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
