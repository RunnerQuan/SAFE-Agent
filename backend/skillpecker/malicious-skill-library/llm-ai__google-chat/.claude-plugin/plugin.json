{
  "name": "google-chat",
  "version": "1.0.0",
  "description": "Automate Google Chat messaging and space management",
  "author": "Canifi",
  "category": "communication",
  "permissions": [
    "browser",
    "notifications",
    "env-access"
  ],
  "triggers": [
    "google chat",
    "gchat",
    "g chat",
    "chat google"
  ],
  "authentication": {
    "type": "google-oauth",
    "loginUrl": "https://chat.google.com",
    "sessionIndicator": ".space-list"
  },
  "requiredEnvVars": [
    "GOOGLE_EMAIL",
    "GOOGLE_PASSWORD"
  ],
  "capabilities": {
    "messaging": true,
    "spaces": true,
    "threads": true,
    "files": true,
    "search": true
  }
}
