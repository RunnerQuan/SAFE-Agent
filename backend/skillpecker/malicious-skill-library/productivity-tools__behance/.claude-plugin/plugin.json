{
  "name": "behance",
  "displayName": "Behance",
  "version": "1.0.0",
  "description": "Showcase and discover creative work on Behance - manage portfolio projects, explore design trends, and connect with creatives",
  "author": "Canifi LifeOS",
  "category": "Design & Creative",
  "authentication": {
    "type": "browser",
    "loginUrl": "https://www.behance.net/login",
    "loggedInIndicator": "[data-testid='user-avatar']"
  },
  "capabilities": [
    "browse-projects",
    "manage-portfolio",
    "save-moodboards",
    "follow-creatives",
    "adobe-integration",
    "discover-trends"
  ],
  "requiredEnvVars": [
    "BEHANCE_EMAIL",
    "BEHANCE_PASSWORD"
  ],
  "endpoints": {
    "base": "https://www.behance.net",
    "galleries": "https://www.behance.net/galleries",
    "search": "https://www.behance.net/search"
  },
  "rateLimit": {
    "requests": 60,
    "period": "minute"
  }
}
