{
  "name": "facebook",
  "version": "1.0.0",
  "description": "Automate Facebook posts, pages, groups, and social engagement",
  "author": "Canifi",
  "category": "social-media",
  "permissions": [
    "browser",
    "notifications",
    "env-access"
  ],
  "triggers": [
    "facebook",
    "fb",
    "facebook post",
    "post to facebook",
    "facebook page"
  ],
  "authentication": {
    "type": "browser-session",
    "loginUrl": "https://www.facebook.com/login",
    "sessionIndicator": "[aria-label='Facebook']"
  },
  "requiredEnvVars": [
    "FACEBOOK_EMAIL",
    "FACEBOOK_PASSWORD"
  ],
  "capabilities": {
    "posts": true,
    "pages": true,
    "groups": true,
    "engagement": true,
    "events": true,
    "insights": true
  }
}
