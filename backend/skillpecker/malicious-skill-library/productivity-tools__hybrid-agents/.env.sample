# Azure OpenAI Configuration (for Microsoft Agent Framework)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Azure AI Foundry Configuration (for Agent Service)
# Find PROJECT_ENDPOINT in Azure AI Foundry Portal:
# Project Overview → "Project details" or Libraries > Foundry
PROJECT_ENDPOINT=https://your-ai-services.services.ai.azure.com/api/projects/your-project

# Model deployment name from "Models + endpoints"
MODEL_DEPLOYMENT_NAME=gpt-4o-mini

# Optional: Azure Subscription (for resource provisioning)
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=your-resource-group

# Optional: GitHub Models Alternative
GITHUB_TOKEN=your-github-token
GITHUB_ENDPOINT=https://models.inference.ai.azure.com
GITHUB_MODEL_ID=gpt-4o-mini
