# 小红书 Browserless 发布工具 - 环境变量配置
# 复制此文件为 .env 并填写你的配置

# Browserless 服务器地址 (必需)
XHS_WS_URL=ws://your-browserless-server:10086?token=your-token

# 状态文件路径 (可选，默认使用 skill 目录下的 xhs_browser_state.json)
# XHS_STATE_FILE=/path/to/xhs_browser_state.json

# Cookie 文件路径 (可选，默认使用 skill 目录下的 cookies.txt)
# XHS_COOKIE_FILE=/path/to/cookies.txt

# 启用截图调试 (可选，设置为 1 启用，默认禁用)
# XHS_SCREENSHOTS=1
